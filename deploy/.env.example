# --- Auth ---
AUTH_ENABLED=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_ALLOWED_ORG=digimuwi
SESSION_SECRET=          # python3 -c 'import secrets; print(secrets.token_urlsafe(32))'

# --- URLs ---
# BACKEND_DOMAIN is used in the Caddyfile.
# With a real domain:  BACKEND_DOMAIN=api.example.com  (Caddy auto-TLS)
# Without a domain:    BACKEND_DOMAIN=:80               (plain HTTP)
# Free DNS via nip.io: BACKEND_DOMAIN=1.2.3.4.nip.io
BACKEND_DOMAIN=:80
# BACKEND_URL is what the app uses for OAuth callback
BACKEND_URL=http://YOUR_SERVER_IP
FRONTEND_URL=https://digimuwi.github.io/neumes-playground

# --- CORS ---
HTR_CORS_ALLOW_ORIGINS=https://digimuwi.github.io

# --- Git-backed storage ---
DATA_GIT_ENABLED=true
DATA_GIT_PUSH=true
DATA_GIT_REMOTE=origin
DATA_GIT_BRANCH=main
DATA_REPO_ROOT=/app/repo
